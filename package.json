{
  "name": "hiremind",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm --filter './packages/*' build && pnpm --filter './apps/*' build",
    "typecheck": "pnpm --recursive typecheck",
    "lint": "pnpm --recursive lint",
    "db:generate": "pnpm --filter @hiremind/db db:generate",
    "db:migrate": "pnpm --filter @hiremind/db db:migrate",
    "db:push": "pnpm --filter @hiremind/db db:push",
    "db:studio": "pnpm --filter @hiremind/db db:studio",
    "seed": "pnpm --filter @hiremind/db seed",
    "test:e2e": "npx ts-node scripts/run-e2e-test.ts",
    "test:playwright": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/ws": "^8.5.14",
    "next": "^15.5.0",
    "typescript": "^5.7.3",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
